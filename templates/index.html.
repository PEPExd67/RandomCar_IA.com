<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RandomCar.com | Diagnóstico IA</title>
    <style>
        :root {
            --primary-orange: #ff4500;
            --dark-bg: #0f0f0f;
            --card-bg: #1a1a1a;
            --text-gray: #e0e0e0;
            --user-blue: #00acee;
        }

        body { 
            background: var(--dark-bg); 
            color: var(--text-gray); 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            margin: 0; 
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        .header { 
            background: var(--card-bg); 
            padding: 15px 20px; 
            border-bottom: 3px solid var(--primary-orange); 
            text-align: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        .header h1 {
            margin: 0;
            letter-spacing: 2px;
            font-size: 1.5rem;
            color: var(--primary-orange);
        }

        .header p {
            margin: 5px 0 0;
            font-size: 0.8rem;
            text-transform: uppercase;
            opacity: 0.7;
        }

        #chat-container { 
            flex: 1;
            max-width: 900px; 
            margin: 20px auto; 
            width: 95%;
            background: var(--card-bg); 
            border-radius: 10px; 
            display: flex; 
            flex-direction: column; 
            overflow: hidden;
            border: 1px solid #333;
        }

        #messages { 
            flex: 1; 
            overflow-y: auto; 
            padding: 20px; 
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .message {
            padding: 12px 16px;
            border-radius: 8px;
            max-width: 80%;
            line-height: 1.5;
        }

        .bot { 
            background: rgba(255, 69, 0, 0.1);
            border-left: 4px solid var(--primary-orange);
            align-self: flex-start;
        }

        .user { 
            background: rgba(0, 172, 238, 0.1);
            border-right: 4px solid var(--user-blue);
            align-self: flex-end;
            text-align: right;
        }

        .input-area { 
            display: flex; 
            padding: 20px; 
            background: #222;
            gap: 10px;
        }

        input { 
            flex: 1; 
            padding: 12px; 
            border-radius: 5px; 
            border: 1px solid #444; 
            background: #111; 
            color: white; 
            outline: none;
        }

        input:focus {
            border-color: var(--primary-orange);
        }

        button { 
            background: var(--primary-orange); 
            color: white; 
            border: none; 
            padding: 10px 25px; 
            cursor: pointer; 
            border-radius: 5px; 
            font-weight: bold; 
            transition: 0.3s;
        }

        button:hover {
            background: #e63e00;
            transform: scale(1.05);
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>RANDOMCAR.COM</h1>
        <p>SISTEMA DE ASISTENCIA MECÁNICA IA</p>
    </div>

    <div id="chat-container">
        <div id="messages">
            <div class="message bot">
                <b>RandomCar AI:</b> Hola, soy tu experto en mecánica. ¿En qué puedo ayudarte con tu vehículo hoy?
            </div>
        </div>
        <div class="input-area">
            <input type="text" id="user-input" placeholder="Escribe tu duda técnica aquí..." onkeypress="if(event.key === 'Enter') sendMessage()">
            <button onclick="sendMessage()">CONSULTAR</button>
        </div>
    </div>

    <script>
        async function sendMessage() {
            const input = document.getElementById('user-input');
            const msgDiv = document.getElementById('messages');
            const text = input.value.trim();

            if(!text) return;

            // Mostrar mensaje del usuario
            msgDiv.innerHTML += `<div class="message user"><b>Tú:</b><br>${text}</div>`;
            input.value = '';
            msgDiv.scrollTop = msgDiv.scrollHeight;

            try {
                const response = await fetch('/ask', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({message: text})
                });
                
                const data = await response.json();
                
                // Mostrar respuesta de la IA
                msgDiv.innerHTML += `<div class="message bot"><b>RandomCar AI:</b><br>${data.response}</div>`;
                msgDiv.scrollTop = msgDiv.scrollHeight;
            } catch (error) {
                msgDiv.innerHTML += `<div class="message bot" style="color: red;"><b>Error:</b> No se pudo conectar con el servidor.</div>`;
            }
        }
    </script>
</body>
</html>
